# Copy this file to .env and fill only the providers you actually use.
# Keep real secrets out of Git.

# =============================================================================
# 1. Provider API keys
# =============================================================================

# OpenModel key. Used by the recommended Benzimidazoles live extractor profile.
OPENMODEL_API_KEY=replace_me

# OpenAI key, only if you choose an OpenAI Responses/Chat model profile.
OPENAI_API_KEY=

# OpenRouter key, mainly used for embeddings/vector RAG experiments.
OPENROUTER_API_KEY=

# Optional fallback provider key.
NEMOTRON_FALLBACK_API_KEY=


# =============================================================================
# 2. Active ChemX extraction LLM
# =============================================================================
#
# Set this block to the model/provider you want the Benzimidazoles LLM workflow
# to call. Supported API types in code:
#
# - anthropic_messages  -> anthropic.Anthropic(...).messages.create(...)
# - responses           -> OpenAI(...).responses.create(...)
# - chat                -> OpenAI(...).chat.completions.create(...)
#
# Recommended for OpenModel + deepseek-v4-flash, per OpenModel docs:

EXTRACTION_AGENT_PROVIDER=openmodel
EXTRACTION_AGENT_BASE_URL=https://api.openmodel.ai
EXTRACTION_AGENT_API_TYPE=anthropic_messages
EXTRACTION_AGENT_MODEL=deepseek-v4-flash
EXTRACTION_AGENT_API_KEY_ENV=OPENMODEL_API_KEY
EXTRACTION_AGENT_TEMPERATURE=0
EXTRACTION_AGENT_MAX_OUTPUT_TOKENS=8192

# Optional explicit ChemX overrides. If set, these take precedence over the
# EXTRACTION_AGENT_* block above.
CHEMX_LLM_PROVIDER=
CHEMX_LLM_BASE_URL=
CHEMX_LLM_API_TYPE=
CHEMX_LLM_MODEL=
CHEMX_LLM_API_KEY=
CHEMX_LLM_API_KEY_ENV=
CHEMX_LLM_MAX_OUTPUT_TOKENS=


# =============================================================================
# 3. Ready-to-copy model profiles
# =============================================================================

# OpenModel Anthropic Messages profile for DeepSeek V4 Flash:
# EXTRACTION_AGENT_PROVIDER=openmodel
# EXTRACTION_AGENT_BASE_URL=https://api.openmodel.ai
# EXTRACTION_AGENT_API_TYPE=anthropic_messages
# EXTRACTION_AGENT_MODEL=deepseek-v4-flash
# EXTRACTION_AGENT_API_KEY_ENV=OPENMODEL_API_KEY

# OpenAI Responses profile:
# EXTRACTION_AGENT_PROVIDER=openai
# EXTRACTION_AGENT_BASE_URL=https://api.openai.com/v1
# EXTRACTION_AGENT_API_TYPE=responses
# EXTRACTION_AGENT_MODEL=gpt-5-mini
# EXTRACTION_AGENT_API_KEY_ENV=OPENAI_API_KEY

# OpenAI-compatible Chat Completions profile:
# EXTRACTION_AGENT_PROVIDER=openai_compatible
# EXTRACTION_AGENT_BASE_URL=https://your-provider.example/v1
# EXTRACTION_AGENT_API_TYPE=chat
# EXTRACTION_AGENT_MODEL=your-chat-model
# EXTRACTION_AGENT_API_KEY_ENV=YOUR_PROVIDER_API_KEY


# =============================================================================
# 4. Optional evidence selector model profile
# =============================================================================
#
# The current Benzimidazoles Evidence Selector is deterministic and does not
# need a live model. Keep this block for future controlled selector experiments.

EVIDENCE_SELECTOR_PROVIDER=openmodel
EVIDENCE_SELECTOR_BASE_URL=https://api.openmodel.ai/v1
EVIDENCE_SELECTOR_API_TYPE=anthropic_messages
EVIDENCE_SELECTOR_MODEL=deepseek-v4-flash
EVIDENCE_SELECTOR_API_KEY_ENV=OPENMODEL_API_KEY
EVIDENCE_SELECTOR_TEMPERATURE=0
EVIDENCE_SELECTOR_MAX_OUTPUT_TOKENS=4096


# =============================================================================
# 5. Optional fallback extraction model
# =============================================================================

EXTRACTION_FALLBACK_ENABLED=true
EXTRACTION_FALLBACK_PROVIDER=
EXTRACTION_FALLBACK_BASE_URL=
EXTRACTION_FALLBACK_API_TYPE=
EXTRACTION_FALLBACK_MODEL=nemotron-3-ultra
EXTRACTION_FALLBACK_API_KEY_ENV=NEMOTRON_FALLBACK_API_KEY
EXTRACTION_FALLBACK_TEMPERATURE=0
EXTRACTION_FALLBACK_MAX_OUTPUT_TOKENS=8192


# =============================================================================
# 6. RAG / embeddings experiments
# =============================================================================
#
# RAG is project memory only. It is not the benchmark extraction engine.

RAG_EMBEDDINGS_PROVIDER=openrouter
RAG_EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
RAG_EMBEDDINGS_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
RAG_EMBEDDINGS_API_KEY_ENV=OPENROUTER_API_KEY
RAG_EMBEDDINGS_BATCH_SIZE=64

RAG_BM25_FALLBACK_ENABLED=true
RAG_BM25_TOP_K=20
RAG_VECTOR_TOP_K=20
RAG_HYBRID_TOP_K=30
RAG_MIN_VECTOR_SCORE=

RAG_VECTOR_STORE=chroma
RAG_VECTOR_PERSIST_DIR=rag_index/vector_chroma
RAG_VECTOR_COLLECTION=methodology_notes


# =============================================================================
# 7. Local validation / normalization
# =============================================================================

LLM_JSON_ONLY=true
VALIDATOR_ENGINE=local
VALIDATOR_USE_PYDANTIC=true
VALIDATOR_USE_REGEX=true
VALIDATOR_USE_DICTIONARIES=true
VALIDATOR_USE_RDKIT=true
VALIDATOR_MISSING_VALUE=NOT_DETECTED

BACTERIA_ALIASES_PATH=config/domains/benzimidazoles.yaml
DOMAIN_CONFIG_PATH=config/domains/benzimidazoles.yaml


# =============================================================================
# 8. Export / evaluation paths
# =============================================================================

DEFAULT_DOMAIN=benzimidazoles
DEFAULT_OUTPUT_DIR=outputs/benzimidazoles
CHEMX_SCHEMA=benzimidazoles
CHEMX_COLUMNS=compound_id,smiles,target_type,target_relation,target_value,target_units,bacteria

EXPORT_PREDICTIONS_CSV=outputs/benzimidazoles/predictions.csv
EXPORT_PREDICTIONS_JSON=outputs/benzimidazoles/predictions.json
EXPORT_METRICS_JSON=outputs/benzimidazoles/metrics.json
EXPORT_FIELD_METRICS_CSV=outputs/benzimidazoles/field_metrics.csv


# =============================================================================
# 9. Optional local structure-recognition tools
# =============================================================================

MOLSCRIBE_MODEL_PATH=
MOLSCRIBE_DEVICE=cpu
RXNSCRIBE_MODEL_PATH=
RXNSCRIBE_DEVICE=cpu
YOLO_MODEL_PATH=
